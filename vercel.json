{
    "version": 2,
    "builds": [
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "public/chatbot.html"
        },
        {
            "src": "/statics/user.png",
            "dest": "public/statics/user.png"
        },
        {
            "src": "/statics/robot.png",
            "dest": "public/statics/robot.png"
        }
    ]
}